{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "compose: up",
      "type": "shell",
      "command": "docker compose up -d",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "compose: down",
      "type": "shell",
      "command": "docker compose down",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "compose: down -v",
      "type": "shell",
      "command": "docker compose down -v",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "spark: smoke test",
      "type": "shell",
      "command": "docker compose exec spark /opt/spark/bin/spark-sql -f /opt/spark/scripts/smoke-test.sql",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "ui: logs",
      "type": "shell",
      "command": "docker compose logs --tail=200 ui",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}